# 数据库路径（相对于项目根目录）
DATABASE_URL=sqlite:///data/video_crawler.db

# 服务端口
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# B站爬取限速（每分钟请求数）
BILIBILI_RPM=30

# 抖音爬取限速（每分钟请求数）
DOUYIN_RPM=10

# YouTube Data API Key（需自行申请）
YOUTUBE_API_KEY=

# 通知配置（apprise URL，多个用逗号分隔）
# 示例: tgram://bot_token/chat_id, serverchan://sendkey
NOTIFY_URLS=

# 日志级别
LOG_LEVEL=INFO
